##BEISPIEL
#######################

library(terra)
library(sf)
library(leastcostpath)

# Raster (Resistance)
r <- rast(nrows = 20, ncols = 20)
values(r) <- runif(ncell(r)) + 0.1

# Start- und Zielpunkt
from <- c(xmin(r), ymin(r))
to   <- c(xmax(r), ymax(r))

# Funktion testen
lcp <- calculate_lcp(r, from, to)

# Ergebnis ansehen
lcp

plot(r, mar = c(3, 3, 2, 5))
plot(sf::st_geometry(lcp), add = TRUE, col = "blue", lwd = 2)

dev.new(width = 7, height = 7)

plot(r, col = terrain.colors(50), main = "Least Cost Path")
points(sf::st_coordinates(sf::st_geometry(lcp)), col = "red", pch = 16)
plot(sf::st_geometry(lcp), add = TRUE, col = "blue", lwd = 3)

