#' Convert suitability raster to resistance surface
#'
#' This function transforms a habitat suitability raster into a resistance
#' raster for connectivity analysis.
#'
#' @param raster A SpatRaster with suitability values (0–1)
#' @param method Method for transformation ("inverse" or "complement")
#' @param epsilon Small constant to avoid division by zero (default = 1e-6)
#' @return A SpatRaster representing resistance values
#' @examples
#' library(terra)
#' r <- rast(nrows=20, ncols=20)
#' values(r) <- runif(ncell(r))
#' res1 <- suitability_to_resistance(r, method = "inverse")
#' res2 <- suitability_to_resistance(r, method = "complement")
#' par(mfrow = c(1, 3))
#' plot(r, main = "Suitability")
#' plot(res1, main = "Resistance (inverse)")
#' plot(res2, main = "Resistance (complement)")
#' @export

suitability_to_resistance <- function(raster, method = "inverse", epsilon = 1e-6) {
  
  # Checks
  if (!inherits(raster, "SpatRaster")) {
    stop("raster must be a SpatRaster object (terra package)")
  }
  
  if (!method %in% c("inverse", "complement")) {
    stop("method must be 'inverse' or 'complement'")
  }
  
  # Transformation
  if (method == "inverse") {
    resistance <- 1 / (raster + epsilon)
  }
  
  if (method == "complement") {
    resistance <- 1 - raster
  }
  
  return(resistance)
}


############################
###BEISPIEL
#####################


library(terra)

# Beispiel: Suitability Raster (0–1)
r <- rast(nrows=20, ncols=20)
values(r) <- runif(ncell(r))  # Werte zwischen 0 und 1

# Umwandlung
res1 <- suitability_to_resistance(r, method = "inverse")
res2 <- suitability_to_resistance(r, method = "complement")

# Plot
par(mfrow = c(1, 3))
plot(r, main = "Suitability")
plot(res1, main = "Resistance (inverse)")
plot(res2, main = "Resistance (complement)")